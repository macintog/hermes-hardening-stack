+        content="",
+        attachments=[att],
+        mentions=[],
+        reference=None,
+        created_at=datetime.now(timezone.utc),
+        guild=None,
+        channel=_FakeDMChannel(),
+        author=SimpleNamespace(id=42, display_name="U", name="U"),
