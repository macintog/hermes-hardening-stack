+class TestSafeHttpFallbackMigration:
+    @pytest.mark.asyncio
+    async def test_image_url_fallback_uses_safe_http_with_media_allowlist(self):
+        adapter = _make_adapter()
+        att = _make_attachment_without_read()
+
+        with patch(
+            "gateway.platforms.discord.safe_download_bytes",
+            new_callable=AsyncMock,
+            return_value=SimpleNamespace(content=_PNG_BYTES, content_type="image/png"),
+        ) as mock_download, patch(
+            "gateway.platforms.discord.cache_image_from_bytes",
+            return_value="/tmp/safe-image.png",
+        ) as mock_cache:
+            result = await adapter._cache_discord_image(att, ".png")
+
+        assert result == "/tmp/safe-image.png"
+        kwargs = mock_download.await_args.kwargs
+        assert mock_download.await_args.args == (att.url,)
+        assert kwargs["source_type"] == "discord_attachment_image_fallback"
+        assert kwargs["max_bytes"] == adapter.DISCORD_IMAGE_FALLBACK_MAX_BYTES
+        assert "image/png" in kwargs["allowed_content_types"]
+        mock_cache.assert_called_once_with(_PNG_BYTES, ext=".png")
+
