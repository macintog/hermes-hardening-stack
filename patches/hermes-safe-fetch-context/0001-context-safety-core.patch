+def _scan_skill_content_for_view(
+    content: str,
+    source_label: str,
+    provenance: str = "local",
+    plugin_namespace: str | None = None,
+) -> Dict[str, Any]:
+    """Scan skill_view content without rewriting or implying enforcement.
+
+    skill_view is report-only: it surfaces findings for callers, but does not
+    block, fence, or rewrite returned content. Keep scanner verdicts available
+    as raw_verdict while exposing a non-actionable presentation verdict.
+    """
+    result = scan_context_text(
+        content,
+        surface=ContextSurface.SKILL_CONTENT,
+        source_label=source_label,
+    )
+    serialized = _serialize_context_safety_result(result)
+    serialized["raw_verdict"] = result.verdict.value
+    serialized["verdict"] = "warn" if serialized["finding_count"] else "safe"
+    serialized["provenance"] = provenance
+    serialized["enforcement"] = "report_only"
+    if plugin_namespace is not None:
+        serialized["plugin_namespace"] = plugin_namespace
+    return serialized
+
