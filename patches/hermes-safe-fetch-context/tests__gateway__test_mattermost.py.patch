+    @pytest.mark.asyncio
+    async def test_inbound_private_base_url_attachment_downloads_via_safe_http(self, monkeypatch):
+        """Configured private Mattermost origins are allowed for inbound files only."""
+        self.adapter._base_url = "http://127.0.0.1:8065"
+        self.adapter._token = "private-token"
+        self.adapter._api_get = AsyncMock(return_value={
+            "name": "report.txt",
+            "mime_type": "text/plain",
+        })
+        monkeypatch.setattr("tools.safe_http.is_safe_url", lambda _url: False)
+
+        requests = []
+
+        async def handler(request):
+            requests.append(request)
+            assert request.url == httpx.URL("http://127.0.0.1:8065/api/v4/files/file_private")
+            assert request.headers["Authorization"] == "Bearer private-token"
+            return httpx.Response(200, headers={"Content-Type": "text/plain"}, content=b"private file")
+
+        from tools.safe_http import safe_download_bytes as real_safe_download_bytes
+
+        async def safe_download_with_mock_transport(*args, **kwargs):
+            kwargs["transport"] = httpx.MockTransport(handler)
+            return await real_safe_download_bytes(*args, **kwargs)
+
+        monkeypatch.setattr(
+            "gateway.platforms.mattermost.safe_download_bytes",
+            safe_download_with_mock_transport,
+        )
+
+        post_data = {
+            "id": "post_file",
+            "user_id": "user_123",
+            "channel_id": "chan_dm",
+            "message": "see attached",
+            "file_ids": ["file_private"],
+        }
+        event = {
+            "event": "posted",
+            "data": {
+                "post": json.dumps(post_data),
+                "channel_type": "D",
+                "sender_name": "@alice",
+            },
+        }
+
+        await self.adapter._handle_ws_event(event)
+
+        assert len(requests) == 1
+        assert self.adapter.handle_message.called
+        msg_event = self.adapter.handle_message.call_args[0][0]
+        assert msg_event.media_urls and msg_event.media_urls[0].endswith("report.txt")
+        assert msg_event.media_types == ["text/plain"]
+
 
