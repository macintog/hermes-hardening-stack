+    @pytest.mark.asyncio
+    async def test_inbound_attachment_uses_safe_download_with_auth_and_cap(self):
+        """Mattermost attachment downloads are credential-bearing and capped locally."""
+        from tools.safe_http import SafeHTTPResult
+
+        self.adapter._api_get = AsyncMock(return_value={"name": "photo.png", "mime_type": "image/png"})
+
+        async def fake_download(url, **kwargs):
+            assert url == "https://mm.example.com/api/v4/files/file1"
+            assert kwargs["headers"] == {"Authorization": "Bearer test-token"}
+            assert kwargs["max_bytes"] == 50 * 1024 * 1024
+            assert kwargs["source_type"] == "mattermost_inbound_file"
+            assert kwargs["policy"]["credentialed"] is True
+            return SafeHTTPResult(
+                content=b"\x89PNG fake", source_url=url, final_url=url,
+                status_code=200, content_type="image/png", content_length=9,
+                bytes_read=9, sha256="abc", source_type=kwargs["source_type"],
+                policy=kwargs["policy"], headers={},
+            )
+
+        self.adapter._session = MagicMock()
+        self.adapter._session.get = MagicMock()
+        with patch("gateway.platforms.mattermost.safe_download_bytes", side_effect=fake_download), \
+             patch("gateway.platforms.base.cache_image_from_bytes", return_value="/tmp/photo.png"):
+            await self.adapter._handle_ws_event(self._make_event(["file1"]))
+
+        assert not self.adapter._session.get.called
+        msg = self.adapter.handle_message.call_args[0][0]
+        assert msg.media_urls == ["/tmp/photo.png"]
