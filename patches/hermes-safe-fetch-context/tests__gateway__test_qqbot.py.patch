+class TestQQBotSafeDownloads:
+    def _make_adapter(self, **extra):
+        from gateway.platforms.qqbot import QQAdapter
+        adapter = QQAdapter(_make_config(**extra))
+        adapter._http_client = mock.MagicMock()
+        adapter._access_token = "secret-token"
+        return adapter
+
+    @pytest.mark.asyncio
+    async def test_download_and_cache_uses_safe_download_with_qq_credentials(self):
+        adapter = self._make_adapter(app_id="a", client_secret="b")
+
+        async def fake_download(url, **kwargs):
+            assert url == "https://multimedia.nt.qq.com.cn/path/image.jpg?sig=secret"
+            assert kwargs["max_bytes"] == adapter._QQBOT_IMAGE_DOWNLOAD_MAX_BYTES
+            assert kwargs["source_type"] == "qqbot_attachment"
+            assert kwargs["headers"] == {"Authorization": "QQBot secret-token"}
+            assert kwargs["policy"]["credentialed"] is True
+            return mock.Mock(content=b"image-bytes")
+
+        with mock.patch("gateway.platforms.qqbot.adapter.safe_download_bytes", side_effect=fake_download):
+            with mock.patch("gateway.platforms.qqbot.adapter.cache_image_from_bytes", return_value="/tmp/cached.jpg") as cache:
+                result = await adapter._download_and_cache(
+                    "https://multimedia.nt.qq.com.cn/path/image.jpg?sig=secret", "image/jpeg"
+                )
+
+        assert result == "/tmp/cached.jpg"
+        cache.assert_called_once_with(b"image-bytes", ".jpg")
+        adapter._http_client.get.assert_not_called()
+
+    @pytest.mark.asyncio
+    async def test_download_and_cache_blocks_redirect_to_private_target(self):
+        adapter = self._make_adapter(app_id="a", client_secret="b")
+
+        async def handler(request):
+            if request.url.host == "example.com":
+                return httpx.Response(302, headers={"Location": "http://127.0.0.1/private"})
+            return httpx.Response(200, content=b"nope")
+
+        transport = httpx.MockTransport(handler)
+        from tools.safe_http import safe_download_bytes as real_safe_download
+
+        async def call_real(url, **kwargs):
+            kwargs["transport"] = transport
+            return await real_safe_download(url, **kwargs)
+
+        with mock.patch("gateway.platforms.qqbot.adapter.safe_download_bytes", side_effect=call_real):
+            result = await adapter._download_and_cache("https://example.com/image.jpg", "image/jpeg")
+
+        assert result is None
+
+    @pytest.mark.asyncio
+    async def test_download_and_cache_blocks_oversized_response(self):
+        adapter = self._make_adapter(app_id="a", client_secret="b")
+        payload = b"x" * (adapter._QQBOT_IMAGE_DOWNLOAD_MAX_BYTES + 1)
+
+        async def handler(request):
+            return httpx.Response(200, content=payload, headers={"Content-Type": "image/jpeg"})
+
+        transport = httpx.MockTransport(handler)
+        from tools.safe_http import safe_download_bytes as real_safe_download
+
+        async def call_real(url, **kwargs):
+            kwargs["transport"] = transport
+            return await real_safe_download(url, **kwargs)
+
+        with mock.patch("gateway.platforms.qqbot.adapter.safe_download_bytes", side_effect=call_real):
+            result = await adapter._download_and_cache("https://example.com/image.jpg", "image/jpeg")
+
+        assert result is None
+
+    @pytest.mark.asyncio
+    async def test_stt_blocks_credentialed_cross_origin_redirect(self):
+        adapter = self._make_adapter(app_id="a", client_secret="b")
+
+        async def handler(request):
+            if request.url.host == "multimedia.nt.qq.com.cn":
+                assert request.headers.get("Authorization") == "QQBot secret-token"
+                return httpx.Response(302, headers={"Location": "https://cdn.example.net/voice.wav"})
+            return httpx.Response(200, content=b"RIFF0123456789")
+
+        transport = httpx.MockTransport(handler)
+        from tools.safe_http import safe_download_bytes as real_safe_download
+
+        async def call_real(url, **kwargs):
+            kwargs["transport"] = transport
+            return await real_safe_download(url, **kwargs)
+
+        with mock.patch("gateway.platforms.qqbot.adapter.safe_download_bytes", side_effect=call_real):
+            transcript = await adapter._stt_voice_attachment(
+                "https://multimedia.nt.qq.com.cn/voice.wav?token=***",
+                "audio/wav",
+                "voice.wav",
+            )
+
+        assert transcript is None
+
