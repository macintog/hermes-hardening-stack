+    GATEWAY_PLATFORM_METADATA = "gateway_platform_metadata"
+    EXTRACTION_OUTPUT = "extraction_output"
+
+
+@dataclass(frozen=True)
+class IntentSegment:
+    kind: IntentSegmentKind
+    text: str
+    surface: ContextSurface | None = None
+    source_label: str | None = None
+    trusted_for_authority: bool = False
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "kind": self.kind.value,
+            "text": self.text,
+            "surface": self.surface.value if self.surface else None,
+            "source_label": self.source_label,
+            "trusted_for_authority": self.trusted_for_authority,
+        }
+
+
+@dataclass(frozen=True)
+class ActiveUserIntent:
+    segments: tuple[IntentSegment, ...]
+
+    @property
+    def active_text(self) -> str:
+        return "\n".join(s.text for s in self.segments if s.trusted_for_authority and s.text).strip()
+
+    @property
+    def evidence_text(self) -> str:
+        return "\n\n".join(s.text for s in self.segments if not s.trusted_for_authority and s.text).strip()
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "active_text": self.active_text,
+            "evidence_text": self.evidence_text,
+            "segments": [s.to_dict() for s in self.segments],
+        }
+
+
+def active_intent_from_text(active_text: str, evidence_text: str = "") -> ActiveUserIntent:
+    segments: list[IntentSegment] = []
+    if active_text:
+        segments.append(IntentSegment(
+            IntentSegmentKind.ACTIVE_USER_INTENT,
+            active_text,
+            surface=ContextSurface.ACTIVE_USER_INTENT,
+            trusted_for_authority=True,
+        ))
+    if evidence_text:
+        segments.append(IntentSegment(
+            IntentSegmentKind.EXTRACTION_OUTPUT,
+            evidence_text,
+            surface=ContextSurface.EXTRACTION_OUTPUT,
+            trusted_for_authority=False,
+        ))
+    return ActiveUserIntent(tuple(segments))
+
