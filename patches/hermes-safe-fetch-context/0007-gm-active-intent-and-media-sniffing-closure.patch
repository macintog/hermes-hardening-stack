+        if len(fragments) >= 64:
+            return fragments
+    for match in _BASE64_TOKEN_RE.finditer(raw[:20000]):
+        token = match.group(1)
+        if len(token) > 512:
+            continue
+        for decoded in _base64_text_variants(token):
+            add(decoded)
+            if "%" in decoded:
+                add(unquote(decoded))
+        if len(fragments) >= 64:
+            return fragments
+    return fragments
