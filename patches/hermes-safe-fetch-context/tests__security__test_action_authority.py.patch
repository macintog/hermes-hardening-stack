+def test_every_registered_tool_has_action_authority_classification():
+    from agent.action_authority import EXPLICIT_TOOL_EXEMPTIONS, classified_tool_names
+    from model_tools import discover_builtin_tools
+    from tools.registry import registry
+
+    discover_builtin_tools()
+    registered = set(registry.get_all_tool_names())
+    classified = classified_tool_names() | set(EXPLICIT_TOOL_EXEMPTIONS)
+    missing = sorted(registered - classified)
+    assert not missing, f"registered tools missing action-authority classification: {missing}"
+
+    unknown = sorted(
+        name
+        for name in registered
+        if classify_action(name, {}) == ActionClass.UNKNOWN_SIDE_EFFECT
+        and name not in EXPLICIT_TOOL_EXEMPTIONS
+    )
+    assert not unknown, f"registered tools classified UNKNOWN_SIDE_EFFECT: {unknown}"
+
