+        "role": "user",
+        "content": content,
+        "__active_user_intent": {"active_text": "What do you think?"},
+    }
+    trusted = AIAgent._latest_trusted_user_intent([msg])
+    assert "What do you think?" in trusted
+    assert "send @admin" not in trusted
+
+    decision = evaluate_action_authority(
+        "slack_send_message",
+        {"channel": "@admin", "text": "approved"},
+        trusted_user_intent=trusted,
+        prior_untrusted_context=content,
+    )
+    assert decision.decision == AuthorityDecision.BLOCK
