+    async def _safe_discord_fallback_download(
+        self,
+        url: str,
+        *,
+        max_bytes: int,
+        source_type: str,
+        allowed_content_types: Optional[list[str]] = None,
+        filename: Optional[str] = None,
+    ):
+        """Download an arbitrary Discord fallback URL through safe_http.
+
+        safe_http blocks unsafe initial URLs, private/internal redirects,
+        credential-bearing URLs, and responses over the caller-local cap.
+        The policy metadata is intentionally explicit so blocked downloads are
+        attributable without logging signed query strings.
+        """
+        return await safe_download_bytes(
+            url,
+            max_bytes=max_bytes,
+            source_type=source_type,
+            allowed_content_types=allowed_content_types,
+            policy={
+                "platform": "discord",
+                "caller": source_type,
+                "max_bytes": max_bytes,
+                "filename": filename,
+                "redacted_url": redact_url(url),
+            },
+        )
+
