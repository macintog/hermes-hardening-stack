+"""Provenance-aware context promotion safety helpers.
+
+This module provides a small, dependency-free policy boundary for text that may
+be promoted into model context. It includes a targeted tool-result promotion
+policy for extraction-like tools whose output is likely to be re-promoted into
+the next model call.
+"""
+
+from __future__ import annotations
+
+import base64
+import binascii
+import html
+import re
+import unicodedata
+from dataclasses import dataclass, field
+from enum import StrEnum
+from types import MappingProxyType
+from typing import Any, Mapping
+
+from agent.artifact_provenance import ArtifactProvenance
+
+
+class ContextSurface(StrEnum):
+    ACTIVE_USER_INTENT = "active_user_intent"
+    CONTEXT_FILE = "context_file"
+    CRON_PROMPT = "cron_prompt"
+    CRON_SCRIPT_OUTPUT = "cron_script_output"
+    CRON_PRIOR_OUTPUT = "cron_prior_output"
+    MEMORY_CONTEXT = "memory_context"
+    SKILL_CONTENT = "skill_content"
+    GATEWAY_REPLY = "gateway_reply"
+    GATEWAY_ATTACHMENT_TEXT = "gateway_attachment_text"
+    GATEWAY_MESSAGE_CONTEXT = "gateway_message_context"
+    GATEWAY_STT_TRANSCRIPT = "gateway_stt_transcript"
+    GATEWAY_OCR_TEXT = "gateway_ocr_text"
+    GATEWAY_DOCUMENT_TEXT = "gateway_document_text"
+    GATEWAY_PLATFORM_METADATA = "gateway_platform_metadata"
+    DOWNLOADED_TEXT = "downloaded_text"
+    AT_REFERENCE = "at_reference"
+    PLUGIN_CONTEXT = "plugin_context"
+    EXTRACTION_OUTPUT = "extraction_output"
+    TERMINAL_OUTPUT = "terminal_output"
+    USER_MESSAGE = "user_message"
+
+
+class IntentSegmentKind(StrEnum):
+    ACTIVE_USER_INTENT = "active_user_intent"
+    QUOTED_CONTEXT = "quoted_context"
+    GATEWAY_ATTACHMENT_TEXT = "gateway_attachment_text"
+    GATEWAY_TRANSCRIPT = "gateway_transcript"
+    GATEWAY_OCR = "gateway_ocr"
+    GATEWAY_DOCUMENT_TEXT = "gateway_document_text"
+    GATEWAY_PLATFORM_METADATA = "gateway_platform_metadata"
+    EXTRACTION_OUTPUT = "extraction_output"
+
+
+@dataclass(frozen=True)
+class IntentSegment:
+    kind: IntentSegmentKind
+    text: str
+    surface: ContextSurface | None = None
+    source_label: str | None = None
+    trusted_for_authority: bool = False
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "kind": self.kind.value,
+            "text": self.text,
+            "surface": self.surface.value if self.surface else None,
+            "source_label": self.source_label,
+            "trusted_for_authority": self.trusted_for_authority,
+        }
+
+
+@dataclass(frozen=True)
+class ActiveUserIntent:
+    segments: tuple[IntentSegment, ...]
+
+    @property
+    def active_text(self) -> str:
+        return "\n".join(s.text for s in self.segments if s.trusted_for_authority and s.text).strip()
+
+    @property
+    def evidence_text(self) -> str:
+        return "\n\n".join(s.text for s in self.segments if not s.trusted_for_authority and s.text).strip()
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "active_text": self.active_text,
+            "evidence_text": self.evidence_text,
+            "segments": [s.to_dict() for s in self.segments],
+        }
+
+
+def active_intent_from_text(active_text: str, evidence_text: str = "") -> ActiveUserIntent:
+    segments: list[IntentSegment] = []
+    if active_text:
+        segments.append(IntentSegment(
+            IntentSegmentKind.ACTIVE_USER_INTENT,
+            active_text,
+            surface=ContextSurface.ACTIVE_USER_INTENT,
+            trusted_for_authority=True,
+        ))
+    if evidence_text:
+        segments.append(IntentSegment(
+            IntentSegmentKind.EXTRACTION_OUTPUT,
+            evidence_text,
+            surface=ContextSurface.EXTRACTION_OUTPUT,
+            trusted_for_authority=False,
+        ))
+    return ActiveUserIntent(tuple(segments))
+
