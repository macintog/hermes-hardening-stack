+
+_INVISIBLE_CHARS = {
+    "\u200b", "\u200c", "\u200d", "\u2060", "\ufeff",
+    "\u202a", "\u202b", "\u202c", "\u202d", "\u202e",
+    "\u2066", "\u2067", "\u2068", "\u2069",
+}
+
+_LEETSPEAK_TRANSLATION = str.maketrans({
+    "0": "o",
+    "1": "i",
+    "3": "e",
+    "4": "a",
+    "5": "s",
+    "7": "t",
+    "@": "a",
+    "$": "s",
+})
+_BASE64_TOKEN_RE = re.compile(
+    r"(?<![A-Za-z0-9+/=_-])([A-Za-z0-9+/_-]{8,}={0,2})(?![A-Za-z0-9+/=_-])"
+)
+_DOCUMENTATION_CUE_RE = re.compile(
+    r"\b(?:example|examples|sample|fixture|fixtures|test|tests|scanner|detector|"
+    r"detect|rule|regex|pattern|documentation|document|the\s+phrase|the\s+string|"
+    r"contains|mentions|classify|category|prompt\s+injection)\b",
+    re.IGNORECASE,
+)
+_NEGATING_PREFIX_RE = re.compile(
+    r"(?:\bdo\s+not\b|\bdont\b|\bdon['’]?t\b|\bnever\b|\bmust\s+not\b|\bshould\s+not\b)\s*$",
+    re.IGNORECASE,
+)
+_QUOTE_CHARS = "\"'`“”‘’"
+
+
+@dataclass(frozen=True)
+class _ScanCandidate:
+    name: str
+    text: str
+    offsets: tuple[int, ...]
+
+
+def _is_invisible_char(char: str) -> bool:
+    return char in _INVISIBLE_CHARS or unicodedata.category(char) == "Cf"
+
+
+def _normalized_characters(char: str) -> str:
+    return unicodedata.normalize("NFKC", char).lower().translate(_LEETSPEAK_TRANSLATION)
+
+
+def _append_space(chars: list[str], offsets: list[int], idx: int) -> None:
+    if chars and chars[-1] != " ":
+        chars.append(" ")
+        offsets.append(idx)
+
+
+def _scan_candidates(window: str) -> tuple[_ScanCandidate, ...]:
+    """Return normalized scan views plus offset maps into the original window."""
+    spaced_chars: list[str] = []
+    spaced_offsets: list[int] = []
+    compact_chars: list[str] = []
+    compact_offsets: list[int] = []
+
+    for idx, char in enumerate(window):
+        if _is_invisible_char(char):
+            continue
+        for piece in _normalized_characters(char):
+            if _is_invisible_char(piece):
+                continue
+            if piece.isalnum():
+                spaced_chars.append(piece)
+                spaced_offsets.append(idx)
+                compact_chars.append(piece)
+                compact_offsets.append(idx)
+            else:
+                _append_space(spaced_chars, spaced_offsets, idx)
+
+    candidates: list[_ScanCandidate] = []
+    if spaced_chars:
+        candidates.append(_ScanCandidate("normalized", "".join(spaced_chars), tuple(spaced_offsets)))
+    if compact_chars:
+        candidates.append(_ScanCandidate("compact", "".join(compact_chars), tuple(compact_offsets)))
+    return tuple(candidates)
+
+
+def _candidate_span_to_window_offsets(candidate: _ScanCandidate, start: int, end: int) -> tuple[int, int]:
+    if not candidate.offsets:
+        return (0, 0)
+    start = max(0, min(start, len(candidate.offsets) - 1))
+    end = max(start + 1, min(end, len(candidate.offsets)))
+    covered = candidate.offsets[start:end]
+    return (min(covered), max(covered) + 1)
+
+
+def _base64_text_variants(value: str) -> list[str]:
+    stripped = value.strip()
+    if len(stripped) < 8 or len(stripped) > 512:
+        return []
+    if not re.fullmatch(r"[A-Za-z0-9+/=_-]+", stripped):
+        return []
+    padded = stripped + "=" * (-len(stripped) % 4)
+    variants: list[str] = []
+    for candidate in {padded, padded.replace("-", "+").replace("_", "/")}:
+        try:
+            decoded = base64.b64decode(candidate, validate=False)
+        except (binascii.Error, ValueError):
+            continue
+        try:
+            text = decoded.decode("utf-8")
+        except UnicodeDecodeError:
+            continue
+        if 4 <= len(text) <= 512 and all(ch.isprintable() or ch.isspace() for ch in text):
+            variants.append(text)
+    return variants
+
+
+def _is_documentation_mention(text: str, start: int, end: int) -> bool:
+    line_start = text.rfind("\n", 0, start) + 1
+    line_end = text.find("\n", end)
+    if line_end == -1:
+        line_end = len(text)
+    line = text[line_start:line_end]
+    if not _DOCUMENTATION_CUE_RE.search(line):
+        return False
+    local_start = start - line_start
+    local_end = end - line_start
+    before = line[:local_start]
+    after = line[local_end:]
+    quoted = (
+        (before.rstrip().endswith(tuple(_QUOTE_CHARS)) and after.lstrip().startswith(tuple(_QUOTE_CHARS)))
+        or ("`" in before and "`" in after)
+        or ('"' in before and '"' in after)
+    )
+    return quoted
+
+
+def _is_negated_instruction_override(rule_id: str, text: str, start: int) -> bool:
+    if not (rule_id.startswith("instruction_override") or rule_id == "prompt_injection"):
+        return False
+    prefix = text[max(0, start - 64):start]
+    normalized = re.sub(r"[^a-z0-9'’]+", " ", prefix.lower()).strip()
+    return bool(_NEGATING_PREFIX_RE.search(normalized))
+
+
+def _adjust_finding_severity(
+    surface: ContextSurface,
+    severity: FindingSeverity,
+    category: str,
+    text: str,
+    start: int,
+    end: int,
+) -> FindingSeverity:
+    if (
+        surface == ContextSurface.CONTEXT_FILE
+        and severity in {FindingSeverity.HIGH, FindingSeverity.CRITICAL}
+        and category in {"prompt_injection", "prompt_disclosure", "prompt_boundary", "tool_action_steering"}
+        and _is_documentation_mention(text, start, end)
+    ):
+        return FindingSeverity.MEDIUM
+    return severity
