+def _is_path_under(candidate: Path, root: Path) -> bool:
+    """Return True if candidate is under root, tolerating missing paths/symlinks."""
+    for cand, base in ((candidate, root), (candidate.resolve(), root.resolve())):
+        try:
+            cand.relative_to(base)
+            return True
+        except (ValueError, OSError):
+            continue
+    return False
+
+
+def _skill_content_provenance(skill_path: Path, external_dirs: List[Path]) -> str:
+    """Classify non-plugin skill content as local or external for context safety."""
+    if _is_path_under(skill_path, SKILLS_DIR):
+        return "local"
+    for external_dir in external_dirs:
+        if _is_path_under(skill_path, external_dir):
+            return "external"
+    return "local"
+
