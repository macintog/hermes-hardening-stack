+def _serialize_context_safety_finding(finding: ContextFinding) -> Dict[str, Any]:
+    """Return a stable, JSON-safe representation of a context-safety finding."""
+    rule_id = finding.rule_id
+    if rule_id == "prompt_injection":
+        rule_id = "prompt_injection_ignore"
+    return {
+        "rule_id": rule_id,
+        "severity": getattr(finding.severity, "value", finding.severity),
+        "category": finding.category,
+        "description": finding.description,
+        "surface": getattr(finding.surface, "value", finding.surface),
+        "source_label": finding.source_label,
+        "line": finding.line,
+        "start": finding.start,
+        "end": finding.end,
+        "snippet": finding.excerpt,
+    }
+
+
+def _serialize_context_safety_result(result: ContextSafetyResult) -> Dict[str, Any]:
+    findings = [_serialize_context_safety_finding(f) for f in result.findings]
+    return {
+        "surface": result.surface.value,
+        "source_label": result.source_label,
+        "verdict": result.verdict.value,
+        "finding_count": len(findings),
+        "findings": findings,
+    }
+
+
+def _scan_skill_content_for_view(
+    content: str,
+    source_label: str,
+    provenance: str = "local",
+    plugin_namespace: str | None = None,
+) -> Dict[str, Any]:
+    """Scan skill_view content without rewriting or implying enforcement.
+
+    skill_view is report-only: it surfaces findings for callers, but does not
+    block, fence, or rewrite returned content. Keep scanner verdicts available
+    as raw_verdict while exposing a non-actionable presentation verdict.
+    """
+    result = scan_context_text(
+        content,
+        surface=ContextSurface.SKILL_CONTENT,
+        source_label=source_label,
+    )
+    serialized = _serialize_context_safety_result(result)
+    serialized["raw_verdict"] = result.verdict.value
+    serialized["verdict"] = "warn" if serialized["finding_count"] else "safe"
+    serialized["provenance"] = provenance
+    serialized["enforcement"] = "report_only"
+    if plugin_namespace is not None:
+        serialized["plugin_namespace"] = plugin_namespace
+    return serialized
+
+
