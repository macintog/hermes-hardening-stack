index 00000000..88e9b1b6
--- /dev/null
+++ b/HARDENING_SURFACE_INVENTORY.md
@@ -0,0 +1,23 @@
+# Hardening Surface Inventory
+
+## Safe-fetch completeness notes
+
+Remote-byte ingress paths verified in this workstream:
+
+- tools.safe_http.safe_download_bytes / safe_download_to_file: central untrusted HTTP download helper. Enforces http/https-only URLs, host presence, userinfo blocking by default, initial and redirect URL safety, max redirects, Content-Length and streaming byte caps, optional content-type allowlists, metadata capture, URL redaction, and same-origin binding for Authorization/Cookie-bearing requests.
+- gateway media/document fallback downloads:
+  - Discord fallback attachment/image/animation paths route through safe_download_bytes. Native discord.py attachment APIs remain platform SDK-controlled; fallback arbitrary URLs are safe-fetch protected.
+  - Telegram outbound image URL fallback routes through safe_download_bytes; inbound Telegram file downloads use Telegram Bot API file objects rather than user-supplied arbitrary URLs.
+  - Slack private file/document downloads route through safe_download_bytes with bearer-token headers; safe_http blocks credential-bearing cross-origin redirects.
+  - Mattermost URL-as-file and private file paths route through safe_download_bytes with explicit byte caps and allowed private origin for configured Mattermost server URLs.
+  - WeCom outbound media URL downloads now route through safe_download_bytes with explicit caps and redacted error logging. Inbound encrypted WeCom callback media is decrypted from platform payload bytes, not fetched from arbitrary user URLs.
+  - BlueBubbles inbound attachment downloads now route through safe_download_bytes with an explicit 50 MiB cap and allowed_private_origins restricted to the configured BlueBubbles server origin, preserving local-server compatibility while validating redirects.
+- Web extraction/crawl tools: hosted browser/search/extraction API client calls are service API calls rather than direct user URL byte downloads in-process. Returned page content must still be treated as untrusted and is not prompt-injection safe merely because a service fetched it.
+- Skill/community/GitHub/plugin paths: skill_view now attaches context-safety/provenance/authority metadata to main and linked file reads; external and plugin skill content is evidence-only by default. Well-known/community hub text fetches route through tools.safe_http.safe_download_bytes with URL validation, redirect limits, and byte caps. Plugin pre_llm_call context is fenced as untrusted plugin_context before model visibility.
+- Development/release scripts using requests/httpx are out of live agent/gateway remote-byte ingestion scope unless exposed to user-provided URLs at runtime.
+
+Residual gaps / notes:
+
+- safe_fetch is an ingress control for SSRF, redirects, credentials, caps, and redaction. It does not make fetched content trusted and does not solve prompt injection.
+- Some platform SDK methods perform provider-controlled downloads (for example Telegram and Discord native attachment APIs). They are documented here as equivalent platform-mediated controls, not safe_http call sites.
+- The broad repository still contains many HTTP API client calls for model providers, platform REST APIs, OAuth/websocket flows, and scripts. These are not all remote-byte ingestion of user-supplied URLs; direct download paths should continue to be audited as new platforms/plugins are added.
diff --git a/agent/action_authority.py b/agent/action_authority.py
new file mode 100644
index 00000000..e3e8607e
--- /dev/null
+++ b/agent/action_authority.py
@@ -0,0 +1,232 @@
+"""Deterministic authority gate for model-proposed actions.
+
+This module is intentionally local and dependency-light.  It does not try to
+infer model intent.  It answers one narrow security question: is a proposed
+side-effecting action authorized by trusted user/system/developer policy, or is
+it being authorized only by evidence-only untrusted context?
+"""
+
+from __future__ import annotations
+
+import json
+import re
+from dataclasses import dataclass
+from enum import StrEnum
+from typing import Any, Mapping
+
+
+class AuthorityDecision(StrEnum):
+    ALLOW = "allow"
+    REQUIRE_CONFIRMATION = "require_confirmation"
+    BLOCK = "block"
+
+
+class ActionClass(StrEnum):
+    READ_ONLY_LOCAL_INSPECTION = "read_only_local_inspection"
+    READ_ONLY_NETWORK_FETCH = "read_only_network_fetch"
+    CREDENTIALED_NETWORK_CALL = "credentialed_network_call"
+    FILE_WRITE = "file_write"
+    FILE_DELETE = "file_delete"
+    TERMINAL_EXECUTION = "terminal_execution"
+    SECRET_READ = "secret_read"
+    SECRET_TRANSMISSION = "secret_transmission"
+    OUTBOUND_MESSAGE = "outbound_message"
+    MEMORY_WRITE = "memory_write"
+    CRON_CREATE_UPDATE_DELETE = "cron_create_update_delete"
+    SKILL_PLUGIN_INSTALL_UPDATE = "skill_plugin_install_update"
+    SKILL_PLUGIN_EXECUTE = "skill_plugin_execute"
+    CODE_EXECUTION_FROM_DOWNLOAD = "code_execution_from_download"
+    CONFIGURATION_CHANGE = "configuration_change"
+    UNKNOWN_SIDE_EFFECT = "unknown_side_effect"
+
+
+READ_ONLY_CLASSES = {
+    ActionClass.READ_ONLY_LOCAL_INSPECTION,
+    ActionClass.READ_ONLY_NETWORK_FETCH,
+}
+
+_UNTRUSTED_RE = re.compile(
+    r"<untrusted-context\b(?P<attrs>[^>]*)>(?P<body>.*?)</untrusted-context>",
+    re.IGNORECASE | re.DOTALL,
+)
+_SECRET_PATH_RE = re.compile(
+    r"(^|/)(\.env(?!\.example)|\.netrc|\.pgpass|\.npmrc|\.pypirc|credentials(?:\.|/|$)|secrets?(?:\.|/|$))|"
+    r"(^|/)(id_rsa|id_ed25519|google_application_credentials\.json)$|"
+    r"(^|/)\.ssh(/|$)|(^|/)\.hermes/\.env$",
+    re.IGNORECASE,
+)
+
+_ACTION_KEYWORDS: dict[ActionClass, tuple[str, ...]] = {
+    ActionClass.FILE_WRITE: ("write", "create", "save", "edit", "modify", "patch", "update file"),
+    ActionClass.FILE_DELETE: ("delete", "remove", "rm", "unlink"),
+    ActionClass.TERMINAL_EXECUTION: ("run", "execute", "shell", "terminal", "command", "script"),
+    ActionClass.SECRET_READ: ("secret", "credential", "token", "api key", ".env", "password"),
+    ActionClass.SECRET_TRANSMISSION: ("send", "post", "upload", "exfiltrate", "webhook", "transmit"),
+    ActionClass.OUTBOUND_MESSAGE: ("send", "message", "email", "reply", "post to"),
+    ActionClass.MEMORY_WRITE: ("remember", "memory", "save preference", "profile"),
+    ActionClass.CRON_CREATE_UPDATE_DELETE: ("cron", "schedule", "reminder", "recurring"),
+    ActionClass.SKILL_PLUGIN_INSTALL_UPDATE: ("install", "update", "enable", "disable", "remove skill", "delete skill", "plugin install"),
+    ActionClass.SKILL_PLUGIN_EXECUTE: ("run", "execute", "invoke skill", "use skill"),
+    ActionClass.CREDENTIALED_NETWORK_CALL: ("authenticated", "credential", "api", "post", "put", "patch", "delete"),
+    ActionClass.CONFIGURATION_CHANGE: ("configure", "config", "setting", "enable", "disable"),
+    ActionClass.UNKNOWN_SIDE_EFFECT: ("write", "send", "run", "execute", "delete", "install", "remember"),
+}
+
+
+@dataclass(frozen=True)
+class ActionAuthorityResult:
+    decision: AuthorityDecision
+    action_class: ActionClass
+    reason: str = ""
+    source: str | None = None
+
+    @property
+    def allowed(self) -> bool:
+        return self.decision == AuthorityDecision.ALLOW
+
+    def to_error_payload(self) -> dict[str, Any]:
+        return {
+            "error": "Action authority denied",
+            "decision": self.decision.value,
+            "action_class": self.action_class.value,
+            "reason": self.reason,
+            "authority_source": self.source,
+        }
+
+
+def _stringify(value: Any) -> str:
+    try:
+        return json.dumps(value, ensure_ascii=False, sort_keys=True)
+    except Exception:
+        return str(value)
+
+
+def _untrusted_blocks(text: str) -> list[tuple[str | None, str]]:
+    blocks: list[tuple[str | None, str]] = []
+    for match in _UNTRUSTED_RE.finditer(text or ""):
+        attrs = match.group("attrs") or ""
+        source = None
+        src_match = re.search(r'source="([^"]+)"', attrs)
+        label_match = re.search(r'source_label="([^"]+)"', attrs)
+        if label_match:
+            source = label_match.group(1)
+        elif src_match:
+            source = src_match.group(1)
+        blocks.append((source, match.group("body") or ""))
+    return blocks
+
+
+def _trusted_text_without_untrusted(text: str) -> str:
+    return _UNTRUSTED_RE.sub(" ", text or "")
+
+
+def _contains_action_signal(text: str, action_class: ActionClass) -> bool:
+    low = (text or "").lower()
+    keywords = _ACTION_KEYWORDS.get(action_class, ())
+    if action_class == ActionClass.UNKNOWN_SIDE_EFFECT:
+        keywords = _ACTION_KEYWORDS.get(ActionClass.UNKNOWN_SIDE_EFFECT, ())
+    return any(k in low for k in keywords)
+
+
+def _secretish_path(value: Any) -> bool:
+    if not isinstance(value, str):
+        return False
+    return bool(_SECRET_PATH_RE.search(value.replace("~", "$HOME")))
+
+
+def classify_action(tool_name: str, args: Mapping[str, Any] | None = None) -> ActionClass:
+    """Classify a tool call by side-effect class using deterministic metadata.
+
+    The classifier is intentionally conservative for high-impact tools and can
+    be expanded without changing dispatch code.
+    """
+    name = (tool_name or "").lower()
+    args = args or {}
+
+    if name in {"read_file", "search_files", "session_search", "skills_list", "skill_view"}:
+        if name == "read_file" and any(_secretish_path(v) for v in args.values()):
+            return ActionClass.SECRET_READ
+        return ActionClass.READ_ONLY_LOCAL_INSPECTION
+    if name in {"web_search", "web_extract", "browser_snapshot", "browser_console", "browser_get_images", "vision_analyze"}:
+        return ActionClass.READ_ONLY_NETWORK_FETCH
+    if name in {"write_file", "patch"}:
+        return ActionClass.FILE_WRITE
+    if name in {"terminal", "execute_code"}:
+        command = _stringify(args).lower()
+        if "curl" in command or "wget" in command or "http" in command and any(s in command for s in ("secret", "token", ".env", "credential")):
+            return ActionClass.SECRET_TRANSMISSION
+        return ActionClass.TERMINAL_EXECUTION
+    if name in {"memory"}:
+        return ActionClass.MEMORY_WRITE
+    if name in {"cronjob"}:
+        return ActionClass.CRON_CREATE_UPDATE_DELETE
+    if name in {"send_message", "send_email", "discord_send_message", "slack_send_message"} or "message" in name or "email" in name:
+        return ActionClass.OUTBOUND_MESSAGE
+    if name in {"skill_manage"}:
+        action = str(args.get("action", "")).lower()
+        if action in {"install", "update", "enable", "disable", "remove", "delete"}:
+            return ActionClass.SKILL_PLUGIN_INSTALL_UPDATE
+        return ActionClass.SKILL_PLUGIN_EXECUTE
+    if name.startswith("browser_") and name not in {"browser_snapshot", "browser_console", "browser_get_images"}:
+        return ActionClass.CREDENTIALED_NETWORK_CALL
+    if name.startswith("rl_") and name in {"rl_edit_config", "rl_start_training", "rl_stop_training"}:
+        return ActionClass.CONFIGURATION_CHANGE
+    return ActionClass.UNKNOWN_SIDE_EFFECT
+
+
+def evaluate_action_authority(
+    tool_name: str,
+    args: Mapping[str, Any] | None = None,
+    *,
+    trusted_user_intent: str | None = None,
+    policy_allows_without_user_intent: bool = False,
+) -> ActionAuthorityResult:
+    action_class = classify_action(tool_name, args)
+    arg_text = _stringify(args or {})
+    user_text = trusted_user_intent or ""
+    combined_untrusted = _untrusted_blocks(arg_text) + _untrusted_blocks(user_text)
+    trusted_text = _trusted_text_without_untrusted(user_text)
+
+    if action_class in READ_ONLY_CLASSES:
+        return ActionAuthorityResult(AuthorityDecision.ALLOW, action_class)
+
+    if action_class == ActionClass.UNKNOWN_SIDE_EFFECT and not combined_untrusted:
+        # Preserve compatibility for dynamically registered/plugin/MCP tools
+        # until they grow explicit metadata.  Untrusted-context attempts are
+        # still handled below.
+        return ActionAuthorityResult(AuthorityDecision.ALLOW, action_class)
+
+    if combined_untrusted:
+        untrusted_has_action = any(_contains_action_signal(body, action_class) for _, body in combined_untrusted)
+        trusted_has_action = _contains_action_signal(trusted_text, action_class)
+        args_contain_untrusted = bool(_untrusted_blocks(arg_text))
+        high_risk_untrusted_action = action_class in {ActionClass.SECRET_READ, ActionClass.SECRET_TRANSMISSION}
+        if args_contain_untrusted or high_risk_untrusted_action or (untrusted_has_action and not trusted_has_action):
+            source = next((src for src, _ in combined_untrusted if src), "untrusted_context")
+            return ActionAuthorityResult(
+                AuthorityDecision.BLOCK,
+                action_class,
+                reason="side-effecting action was requested or parameterized by evidence-only untrusted context",
+                source=source,
+            )
+
+    if policy_allows_without_user_intent:
+        return ActionAuthorityResult(AuthorityDecision.ALLOW, action_class)
+
+    if _contains_action_signal(trusted_text, action_class):
+        return ActionAuthorityResult(AuthorityDecision.ALLOW, action_class)
+
+    if trusted_text.strip() and not combined_untrusted:
+        # Trusted user/system/developer tasks often imply required tools without
+        # spelling out implementation verbs (for example date/time lookups,
+        # arithmetic, tests, builds, or repo inspection).  The hard boundary is
+        # that untrusted evidence cannot supply authority; when no untrusted
+        # context is involved, preserve normal agent tool workflows.
+        return ActionAuthorityResult(AuthorityDecision.ALLOW, action_class)
+
+    return ActionAuthorityResult(
+        AuthorityDecision.REQUIRE_CONFIRMATION,
+        action_class,
+        reason="side-effecting action lacks explicit trusted user/system/developer authority",
+        source="trusted_confirmation_required",
+    )
diff --git a/agent/artifact_provenance.py b/agent/artifact_provenance.py
new file mode 100644
index 00000000..3c229c7a
--- /dev/null
+++ b/agent/artifact_provenance.py
@@ -0,0 +1,132 @@
+"""First-class provenance and taint metadata for model-visible artifacts."""
+
+from __future__ import annotations
+
+import hashlib
+from dataclasses import dataclass, field, replace
+from enum import StrEnum
+from types import MappingProxyType
+from typing import Any, Mapping
+
+
+class TrustLevel(StrEnum):
+    TRUSTED = "trusted"
+    USER_SUPPLIED = "user_supplied"
+    EXTERNAL = "external"
+    HOSTILE_UNKNOWN = "hostile_unknown"
+
+
+class ArtifactAuthority(StrEnum):
+    NONE = "none"
+    TRUSTED_USER = "trusted_user"
+    SYSTEM = "system"
+    DEVELOPER = "developer"
+    LOCAL_POLICY = "local_policy"
+
+
+@dataclass(frozen=True)
+class ArtifactProvenance:
+    """Security metadata that follows untrusted content across conversions.
+
+    `authority` is intentionally separate from `trust_level`: externally fetched
+    or recalled content may be useful evidence, but it carries no authority to
+    instruct tools or authorize actions unless a non-model policy explicitly
+    grants it.
+    """
+
+    source_type: str
+    source_label: str | None = None
+    source_url_redacted: str | None = None
+    final_url_redacted: str | None = None
+    sha256: str | None = None
+    content_type: str | None = None
+    status_code: int | None = None
+    bytes_read: int | None = None
+    fetch_policy: Mapping[str, Any] = field(default_factory=lambda: MappingProxyType({}))
+    extraction_chain: tuple[str, ...] = ()
+    trust_level: TrustLevel | str = TrustLevel.EXTERNAL
+    authority: ArtifactAuthority | str = ArtifactAuthority.NONE
+    context_safety: Mapping[str, Any] | None = None
+
+    def __post_init__(self) -> None:
+        object.__setattr__(self, "fetch_policy", MappingProxyType(dict(self.fetch_policy or {})))
+        object.__setattr__(self, "extraction_chain", tuple(self.extraction_chain or ()))
+        object.__setattr__(self, "trust_level", TrustLevel(str(self.trust_level)))
+        object.__setattr__(self, "authority", ArtifactAuthority(str(self.authority)))
+        if self.context_safety is not None:
+            object.__setattr__(self, "context_safety", MappingProxyType(dict(self.context_safety)))
+
+    def with_extraction(self, step: str, *, sha256: str | None = None, bytes_read: int | None = None, content_type: str | None = None) -> "ArtifactProvenance":
+        return replace(
+            self,
+            extraction_chain=self.extraction_chain + (step,),
+            sha256=sha256 if sha256 is not None else self.sha256,
+            bytes_read=bytes_read if bytes_read is not None else self.bytes_read,
+            content_type=content_type if content_type is not None else self.content_type,
+        )
+
+    def with_context_safety(self, safety: Mapping[str, Any]) -> "ArtifactProvenance":
+        return replace(self, context_safety=safety)
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "source_type": self.source_type,
+            "source_label": self.source_label,
+            "source_url_redacted": self.source_url_redacted,
+            "final_url_redacted": self.final_url_redacted,
+            "sha256": self.sha256,
+            "content_type": self.content_type,
+            "status_code": self.status_code,
+            "bytes_read": self.bytes_read,
+            "fetch_policy": dict(self.fetch_policy),
+            "extraction_chain": list(self.extraction_chain),
+            "trust_level": self.trust_level.value,
+            "authority": self.authority.value,
+            "context_safety": dict(self.context_safety) if self.context_safety is not None else None,
+        }
+
+
+def sha256_bytes(data: bytes) -> str:
+    return hashlib.sha256(data).hexdigest()
+
+
+def sha256_text(text: str) -> str:
+    return sha256_bytes(text.encode("utf-8", errors="replace"))
+
+
+def derive_text_provenance(
+    provenance: ArtifactProvenance,
+    text: str,
+    *,
+    step: str,
+    content_type: str = "text/plain; charset=utf-8",
+) -> ArtifactProvenance:
+    encoded = text.encode("utf-8", errors="replace")
+    return provenance.with_extraction(
+        step,
+        sha256=sha256_bytes(encoded),
+        bytes_read=len(encoded),
+        content_type=content_type,
+    )
+
+
+def is_untrusted(provenance: ArtifactProvenance | Mapping[str, Any] | None) -> bool:
+    """Return True if provenance should not be accepted as action authority."""
+    if provenance is None:
+        return True
+    if isinstance(provenance, ArtifactProvenance):
+        return provenance.authority == ArtifactAuthority.NONE or provenance.trust_level in {
+            TrustLevel.EXTERNAL,
+            TrustLevel.HOSTILE_UNKNOWN,
+        }
+    authority = str(provenance.get("authority", ArtifactAuthority.NONE.value))
+    trust_level = str(provenance.get("trust_level", TrustLevel.EXTERNAL.value))
+    return authority == ArtifactAuthority.NONE.value or trust_level in {
+        TrustLevel.EXTERNAL.value,
+        TrustLevel.HOSTILE_UNKNOWN.value,
+    }
+
+
+def assert_has_action_authority(provenance: ArtifactProvenance | Mapping[str, Any] | None) -> None:
+    if is_untrusted(provenance):
+        raise PermissionError("Artifact provenance is untrusted and carries no action authority")
