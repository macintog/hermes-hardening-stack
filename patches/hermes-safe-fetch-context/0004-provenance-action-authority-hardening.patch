+                        surface=ContextSurface.PLUGIN_CONTEXT,
+                        source_label="plugin_pre_llm_call",
+                        max_scan_chars=len(_raw_plugin_context),
+                    ).rendered_text or ""
+                except Exception:
+                    # Fail closed on provenance: keep plugin context visibly fenced
+                    # even if the scanner/fencer import path is unavailable.
+                    _plugin_user_context = (
+                        '<untrusted-context source="plugin_pre_llm_call">\n'
+                        + _raw_plugin_context.replace("</untrusted-context>", "&lt;/untrusted-context&gt;")
+                        + "\n</untrusted-context>"
+                    )
         except Exception as exc:
             logger.warning("pre_llm_call hook failed: %s", exc)
 
diff --git a/tests/security/test_action_authority.py b/tests/security/test_action_authority.py
new file mode 100644
