+    return patch(
+        "tools.safe_http.httpx.AsyncClient",
+        side_effect=lambda **kwargs: real_async_client(
+            transport=httpx.MockTransport(handler),
+            follow_redirects=False,
+            timeout=kwargs.get("timeout"),
+        ),
+    )
