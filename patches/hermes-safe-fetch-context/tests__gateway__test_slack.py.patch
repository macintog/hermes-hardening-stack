+class TestSlackFileDownloadSafety:
+    @pytest.mark.asyncio
+    async def test_download_slack_file_bytes_blocks_redirect_to_private_target(self, adapter):
+        import httpx
+        from tools.safe_http import SafeHTTPError
+
+        async def handler(request):
+            return httpx.Response(
+                302,
+                headers={"Location": "http://127.0.0.1/admin?token=secret"},
+                request=request,
+            )
+
+        with (
+            patch("tools.safe_http.is_safe_url", side_effect=lambda url: not url.startswith("http://127.0.0.1")),
+            _mock_safe_http_client(handler),
+        ):
+            with pytest.raises(SafeHTTPError) as exc:
+                await adapter._download_slack_file_bytes("https://files.slack.com/files-pri/T/F?pub_secret=secret")
+
+        assert "127.0.0.1" in str(exc.value)
+        assert "pub_secret=secret" not in str(exc.value)
+        assert "token=secret" not in str(exc.value)
+
+    @pytest.mark.asyncio
+    async def test_download_slack_file_bytes_blocks_credentialed_cross_origin_redirect(self, adapter):
+        import httpx
+        from tools.safe_http import SafeHTTPError
+
+        seen_authorization = []
+
+        async def handler(request):
+            seen_authorization.append(request.headers.get("authorization"))
+            return httpx.Response(
+                302,
+                headers={"Location": "https://evil.example/steal?signature=secret"},
+                request=request,
+            )
+
+        with (
+            patch("tools.safe_http.is_safe_url", return_value=True),
+            _mock_safe_http_client(handler),
+        ):
+            with pytest.raises(SafeHTTPError) as exc:
+                await adapter._download_slack_file_bytes("https://files.slack.com/files-pri/T/F?pub_secret=secret")
+
+        assert len(seen_authorization) == 1
+        assert seen_authorization[0].startswith("Bearer ")
+        assert "cross-origin redirect" in str(exc.value)
+        assert "pub_secret=secret" not in str(exc.value)
+        assert "signature=secret" not in str(exc.value)
+
+    @pytest.mark.asyncio
+    async def test_download_slack_file_bytes_rejects_oversized_response(self, adapter):
+        import httpx
+        from tools.safe_http import SafeHTTPError
+
+        async def handler(request):
+            return httpx.Response(
+                200,
+                headers={"Content-Length": str(21 * 1024 * 1024)},
+                content=b"x",
+                request=request,
+            )
+
+        with (
+            patch("tools.safe_http.is_safe_url", return_value=True),
+            _mock_safe_http_client(handler),
+        ):
+            with pytest.raises(SafeHTTPError) as exc:
+                await adapter._download_slack_file_bytes("https://files.slack.com/files-pri/T/F?pub_secret=secret")
+
+        assert "too large" in str(exc.value).lower()
+        assert "pub_secret=secret" not in str(exc.value)
+
+
