+    "spotify_albums": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "spotify_devices": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "spotify_playlists": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "spotify_search": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "browser_snapshot": ActionClass.READ_ONLY_NETWORK_FETCH,
+    # browser_console without expression is read-only console retrieval; expression
+    # evaluation executes JavaScript in the credentialed page context and is
+    # classified dynamically in classify_action().
+    "browser_console": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "browser_get_images": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "browser_vision": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "vision_analyze": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "feishu_doc_read": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "feishu_drive_list_comments": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "feishu_drive_list_comment_replies": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "ha_list_entities": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "ha_get_state": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "ha_list_services": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "rl_list_environments": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "rl_get_current_config": ActionClass.READ_ONLY_LOCAL_INSPECTION,
+    "rl_check_status": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "rl_get_results": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "rl_list_runs": ActionClass.READ_ONLY_NETWORK_FETCH,
+    "hermes_customizations": ActionClass.READ_ONLY_LOCAL_INSPECTION,
+    "todo": ActionClass.AGENT_LOOP_INTERNAL,
