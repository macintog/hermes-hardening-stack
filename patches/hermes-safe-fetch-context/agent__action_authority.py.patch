+    "search_files": ActionClass.READ_ONLY_LOCAL_INSPECTION,
+    "session_search": ActionClass.READ_ONLY_LOCAL_INSPECTION,
+    "skills_list": ActionClass.READ_ONLY_LOCAL_INSPECTION,
+    "skill_view": ActionClass.READ_ONLY_LOCAL_INSPECTION,
+    "web_search": ActionClass.READ_ONLY_NETWORK_FETCH,
