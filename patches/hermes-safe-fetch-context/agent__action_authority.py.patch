+    "ha_call_service": ActionClass.CONFIGURATION_CHANGE,
+    "image_generate": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "mixture_of_agents": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "rl_select_environment": ActionClass.CONFIGURATION_CHANGE,
+    "rl_edit_config": ActionClass.CONFIGURATION_CHANGE,
+    "rl_start_training": ActionClass.CONFIGURATION_CHANGE,
+    "rl_stop_training": ActionClass.CONFIGURATION_CHANGE,
+    "rl_test_inference": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "text_to_speech": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "skill_manage": ActionClass.SKILL_PLUGIN_EXECUTE,
+    "browser_navigate": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "browser_click": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "browser_type": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "browser_scroll": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "browser_back": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "browser_press": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "browser_cdp": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "browser_dialog": ActionClass.CREDENTIALED_NETWORK_CALL,
+}
+
+EXPLICIT_TOOL_EXEMPTIONS: dict[str, str] = {
+    "todo": "agent-loop planning state only; mediated by the agent loop",
+    "clarify": "agent-loop user confirmation prompt; cannot perform external side effects by itself",
+    "delegate_task": "agent-loop orchestration primitive; subagent tool calls remain subject to their own authority gates",
+}
+
+def classified_tool_names() -> set[str]:
+    return set(_TOOL_ACTION_CLASSES)
+
+_UNTRUSTED_RE = re.compile(
+    r"<untrusted-context\b(?P<attrs>[^>]*)>(?P<body>.*?)</untrusted-context>",
+    re.IGNORECASE | re.DOTALL,
+)
+_SECRET_PATH_RE = re.compile(
+    r"(^|/)(\.env(?!\.example)|\.netrc|\.pgpass|\.npmrc|\.pypirc|credentials(?:\.|/|$)|secrets?(?:\.|/|$))|"
+    r"(^|/)(id_rsa|id_ed25519|google_application_credentials\.json)$|"
+    r"(^|/)\.ssh(/|$)|(^|/)\.hermes/\.env$",
+    re.IGNORECASE,
+)
+
+_ACTION_KEYWORDS: dict[ActionClass, tuple[str, ...]] = {
+    ActionClass.FILE_WRITE: ("write", "create", "save", "edit", "modify", "patch", "update file"),
+    ActionClass.FILE_DELETE: ("delete", "remove", "rm", "unlink"),
+    ActionClass.TERMINAL_EXECUTION: ("run", "execute", "shell", "terminal", "command", "script"),
+    ActionClass.SECRET_READ: ("secret", "credential", "token", "api key", ".env", "password"),
+    ActionClass.SECRET_TRANSMISSION: ("send", "post", "upload", "exfiltrate", "webhook", "transmit"),
+    ActionClass.OUTBOUND_MESSAGE: ("send", "message", "email", "reply", "post to"),
+    ActionClass.MEMORY_WRITE: ("remember", "memory", "save preference", "profile"),
+    ActionClass.CRON_CREATE_UPDATE_DELETE: ("cron", "schedule", "reminder", "recurring"),
+    ActionClass.SKILL_PLUGIN_INSTALL_UPDATE: ("install", "update", "enable", "disable", "remove skill", "delete skill", "plugin install"),
+    ActionClass.SKILL_PLUGIN_EXECUTE: ("run", "execute", "invoke skill", "use skill"),
+    ActionClass.CREDENTIALED_NETWORK_CALL: ("authenticated", "credential", "api", "post", "put", "patch", "delete", "click", "type", "press", "navigate", "open", "approve"),
+    ActionClass.CONFIGURATION_CHANGE: ("configure", "config", "setting", "enable", "disable"),
+    ActionClass.UNKNOWN_SIDE_EFFECT: ("write", "send", "run", "execute", "delete", "install", "remember"),
+}
+
+
+@dataclass(frozen=True)
+class ActionAuthorityResult:
+    decision: AuthorityDecision
+    action_class: ActionClass
+    reason: str = ""
+    source: str | None = None
+
+    @property
+    def allowed(self) -> bool:
+        return self.decision == AuthorityDecision.ALLOW
+
+    def to_error_payload(self) -> dict[str, Any]:
+        return {
+            "error": "Action authority denied",
+            "decision": self.decision.value,
+            "action_class": self.action_class.value,
+            "reason": self.reason,
+            "authority_source": self.source,
+        }
+
+
+def _stringify(value: Any) -> str:
+    try:
+        return json.dumps(value, ensure_ascii=False, sort_keys=True)
+    except Exception:
+        return str(value)
+
+
+def _untrusted_blocks(text: str) -> list[tuple[str | None, str]]:
+    blocks: list[tuple[str | None, str]] = []
+    for match in _UNTRUSTED_RE.finditer(text or ""):
+        attrs = match.group("attrs") or ""
+        source = None
+        src_match = re.search(r'source="([^"]+)"', attrs)
+        label_match = re.search(r'source_label="([^"]+)"', attrs)
+        if label_match:
+            source = label_match.group(1)
+        elif src_match:
+            source = src_match.group(1)
+        blocks.append((source, match.group("body") or ""))
+    return blocks
+
+
+def _trusted_text_without_untrusted(text: str) -> str:
+    return _UNTRUSTED_RE.sub(" ", text or "")
+
+
+def _contains_action_signal(text: str, action_class: ActionClass) -> bool:
+    low = (text or "").lower()
+    keywords = _ACTION_KEYWORDS.get(action_class, ())
+    if action_class == ActionClass.UNKNOWN_SIDE_EFFECT:
+        keywords = _ACTION_KEYWORDS.get(ActionClass.UNKNOWN_SIDE_EFFECT, ())
+    return any(k in low for k in keywords)
+
+
+def _secretish_path(value: Any) -> bool:
+    if not isinstance(value, str):
+        return False
+    return bool(_SECRET_PATH_RE.search(value.replace("~", "$HOME")))
+
+
+def _flatten_arg_strings(value: Any) -> list[str]:
+    if isinstance(value, str):
+        stripped = value.strip()
+        return [stripped] if stripped else []
+    if isinstance(value, Mapping):
+        values: list[str] = []
+        for item in value.values():
+            values.extend(_flatten_arg_strings(item))
+        return values
+    if isinstance(value, (list, tuple, set)):
+        values: list[str] = []
+        for item in value:
+            values.extend(_flatten_arg_strings(item))
+        return values
+    return []
+
+
+# Authority-bearing fields by side-effect class. The gate intentionally checks
+# the target/scope of the action rather than every byte of data that might be
+# included in a user-authorized side effect.
+_AUTHORITY_TARGET_FIELDS: dict[ActionClass, tuple[str, ...]] = {
+    ActionClass.OUTBOUND_MESSAGE: (
+        "to", "cc", "bcc", "recipient", "recipients", "destination",
+        "channel", "channel_id", "chat_id", "thread_id", "room", "conversation",
+        "webhook", "url", "endpoint", "body", "text", "message", "content",
+    ),
+    ActionClass.FILE_WRITE: ("path", "file", "filename", "filepath", "target", "target_path", "dest", "destination", "directory", "repo_path", "content", "text", "body"),
+    ActionClass.FILE_DELETE: ("path", "file", "filename", "filepath", "target", "target_path", "dest", "destination", "directory", "repo_path"),
+    ActionClass.TERMINAL_EXECUTION: ("command", "cmd", "args", "argv", "script", "code", "program"),
+    ActionClass.SECRET_READ: ("path", "file", "filename", "filepath", "target", "target_path", "command", "cmd", "args", "argv"),
+    ActionClass.SECRET_TRANSMISSION: ("url", "endpoint", "webhook", "host", "headers", "command", "cmd", "args", "argv", "body", "payload", "content"),
+    ActionClass.CREDENTIALED_NETWORK_CALL: (
+        "url", "endpoint", "uri", "origin", "host", "domain", "selector", "css", "css_selector", "xpath",
+        "query", "query_selector", "ref", "target_ref", "target_id", "frame_id",
+        "href", "target", "testid", "data-testid", "aria-label", "text", "value",
+        "button", "label", "name", "expression", "action", "service",
+        "entity_id", "device", "path", "route", "method",
+    ),
+    ActionClass.MEMORY_WRITE: ("key", "name", "content", "value", "note", "memory", "profile_field"),
+    ActionClass.CRON_CREATE_UPDATE_DELETE: ("name", "job_id", "schedule", "prompt", "command", "script"),
+    ActionClass.SKILL_PLUGIN_INSTALL_UPDATE: ("skill", "plugin", "name", "identifier", "url", "source"),
+    ActionClass.SKILL_PLUGIN_EXECUTE: ("skill", "plugin", "name", "identifier", "command", "args"),
+    ActionClass.CONFIGURATION_CHANGE: ("key", "name", "value", "config", "setting", "service", "entity_id", "environment", "run_id"),
+    ActionClass.UNKNOWN_SIDE_EFFECT: ("target", "path", "url", "command", "recipient", "action"),
+}
+
+
+def _field_matches(candidate: str, field_names: tuple[str, ...]) -> bool:
+    low = candidate.lower()
+    tail = low.rsplit(".", 1)[-1]
+    return low in field_names or tail in field_names
+
+
+def _authority_arg_strings_for_fields(value: Any, field_names: tuple[str, ...], *, path: str = "") -> list[str]:
+    if isinstance(value, Mapping):
+        values: list[str] = []
+        for key, item in value.items():
+            next_path = f"{path}.{key}" if path else str(key)
+            if _field_matches(next_path, field_names):
+                values.extend(_flatten_arg_strings(item))
+            else:
+                values.extend(_authority_arg_strings_for_fields(item, field_names, path=next_path))
+        return values
+    if isinstance(value, (list, tuple, set)):
+        values: list[str] = []
+        for item in value:
+            values.extend(_authority_arg_strings_for_fields(item, field_names, path=path))
+        return values
+    return []
+
+
+def _authority_target_strings(tool_name: str, action_class: ActionClass, args: Mapping[str, Any] | None) -> list[str]:
+    if not args:
+        return []
+    fields = _AUTHORITY_TARGET_FIELDS.get(action_class, ())
+    targets = _authority_arg_strings_for_fields(args, fields) if fields else []
+    if not targets and action_class == ActionClass.UNKNOWN_SIDE_EFFECT:
+        targets = _flatten_arg_strings(args)
+    return targets
+
+
+_GENERIC_AUTHORITY_VALUES = {
+    "true", "false", "none", "null", "done", "ok", "yes", "no",
+    "get", "post", "put", "patch", "delete", "create", "update",
+}
+
+
+def _normalize_authority_text(value: str) -> str:
+    low = (value or "").strip().lower()
+    low = unquote(low)
+    low = low.replace("#", " ").replace(".", " ") if low.startswith(("#", ".")) else low
+    low = re.sub(r"[\"'`]+", "", low)
+    low = re.sub(r"\s+", " ", low)
+    return low.strip()
+
+
+def _base64_text_variants(value: str) -> list[str]:
+    stripped = value.strip()
+    if len(stripped) < 8 or len(stripped) > 256:
+        return []
+    if not re.fullmatch(r"[A-Za-z0-9+/=_-]+", stripped):
+        return []
+    padded = stripped + "=" * (-len(stripped) % 4)
+    variants: list[str] = []
+    for candidate in {padded, padded.replace("-", "+").replace("_", "/")}:
+        try:
+            decoded = base64.b64decode(candidate, validate=False)
+        except (binascii.Error, ValueError):
+            continue
+        try:
+            text = decoded.decode("utf-8")
+        except UnicodeDecodeError:
+            continue
+        if text and all(ch.isprintable() or ch.isspace() for ch in text):
+            variants.append(text)
+    return variants
+
+
+
+_BASE64_TOKEN_RE = re.compile(r"(?<![A-Za-z0-9+/=_-])([A-Za-z0-9+/_-]{8,}={0,2})(?![A-Za-z0-9+/=_-])")
+_PERCENT_ENCODED_TOKEN_RE = re.compile(r"(?:[A-Za-z0-9._~:/?#\[\]@!$&'()*+,;=-]*%[0-9A-Fa-f]{2}[A-Za-z0-9._~:/?#\[\]@!$&'()*+,;=%-]*)")
+_BROWSER_REF_RE = re.compile(r"@?e\d+", re.IGNORECASE)
+_SECRET_LIKE_RE = re.compile(
+    r"(?i)(api[_-]?key|authorization|bearer\s+[a-z0-9._~+/=-]{12,}|"
+    r"x-amz-signature|token|secret|password|passwd|private[_-]?key|sessionid|cookie)"
+)
+_NETWORK_TARGET_FIELDS = (
+    "url", "endpoint", "uri", "href", "target", "query", "q", "search",
+    "headers", "header", "body", "payload", "data", "referrer", "referer",
+)
+
+
+def _network_arg_strings(args: Mapping[str, Any] | None) -> list[str]:
+    if not args:
+        return []
+    values = _authority_arg_strings_for_fields(args, _NETWORK_TARGET_FIELDS)
+    return values or _flatten_arg_strings(args)
+
+
+def _url_components_for_egress(value: str) -> list[str]:
+    components = [value]
+    try:
+        parsed = urlsplit(value)
+    except Exception:
+        return components
+    if parsed.path:
+        components.append(unquote(parsed.path))
+    if parsed.query:
+        components.append(unquote(parsed.query))
+        components.extend(unquote(k) for k, _ in parse_qsl(parsed.query, keep_blank_values=True))
+        components.extend(unquote(v) for _, v in parse_qsl(parsed.query, keep_blank_values=True))
+    if parsed.fragment:
+        components.append(unquote(parsed.fragment))
+    if parsed.username:
+        components.append(unquote(parsed.username))
+    if parsed.password:
+        components.append(unquote(parsed.password))
+    return components
+
+
+def _network_egress_risk(
+    args: Mapping[str, Any] | None,
+    trusted_text: str,
+    combined_untrusted: list[tuple[str | None, str]],
+) -> tuple[AuthorityDecision, str, str | None] | None:
+    values = _network_arg_strings(args)
+    if not values:
+        return None
+    untrusted_text = "\n".join(body for _, body in combined_untrusted)
+    private_haystacks = [trusted_text or "", untrusted_text]
+    for value in values:
+        candidates = _url_components_for_egress(value)
+        if any(_SECRET_LIKE_RE.search(candidate or "") for candidate in candidates):
+            if not _value_in_text(value, trusted_text or ""):
+                return (AuthorityDecision.BLOCK, "read-only network egress carries secret-like material", "secret_transmission")
+        if combined_untrusted and _value_in_text(value, untrusted_text) and not _value_in_text(value, trusted_text or ""):
+            return (AuthorityDecision.BLOCK, "read-only network target or transmitted data came from evidence-only untrusted context", next((src for src, _ in combined_untrusted if src), "untrusted_context"))
+        for candidate in candidates:
+            if len(candidate) >= 8 and any(candidate in haystack for haystack in private_haystacks if haystack) and not _value_in_text(candidate, trusted_text or ""):
+                return (AuthorityDecision.BLOCK, "read-only network egress carries private context without trusted scope", "private_context")
+    return None
+
+
+def _decoded_text_fragments(text: str) -> list[str]:
+    fragments: list[str] = []
+    seen: set[str] = set()
+
+    def add(fragment: str) -> None:
+        fragment = fragment.strip()
+        if not fragment or fragment in seen or len(fragment) > 1024:
+            return
+        if all(ch.isprintable() or ch.isspace() for ch in fragment):
+            seen.add(fragment)
+            fragments.append(fragment)
+
+    raw = text or ""
+    if "%" in raw:
+        add(unquote(raw))
+    for match in _PERCENT_ENCODED_TOKEN_RE.finditer(raw[:20000]):
+        add(unquote(match.group(0)))
+        if len(fragments) >= 64:
+            return fragments
+    for match in _BASE64_TOKEN_RE.finditer(raw[:20000]):
+        token = match.group(1)
+        if len(token) > 512:
+            continue
+        for decoded in _base64_text_variants(token):
+            add(decoded)
+            if "%" in decoded:
+                add(unquote(decoded))
+        if len(fragments) >= 64:
+            return fragments
+    return fragments
+
+
+def _browser_selector_value_variants(value: str) -> set[str]:
+    raw = (value or "").strip()
+    variants: set[str] = set()
+    if not raw:
+        return variants
+    normalized = _normalize_authority_text(raw)
+    variants.add(normalized)
+    ref_match = _BROWSER_REF_RE.fullmatch(raw.lstrip("@")) or _BROWSER_REF_RE.fullmatch(raw)
+    if ref_match:
+        ref = raw.lower().lstrip("@")
+        variants.update({ref, f"@{ref}", f"ref={ref}", f"[ref={ref}]"})
+    for quoted in re.findall(r"[\[\(]?(?:data-testid|aria-label|name|text|role)[=:\[]+[\"']?([^\"'\]\)]+)", raw, flags=re.IGNORECASE):
+        variants.add(_normalize_authority_text(quoted))
+    for quoted in re.findall(r"[\"']([^\"']{2,120})[\"']", raw):
+        variants.add(_normalize_authority_text(quoted))
+    if raw.startswith(("#", ".")) and len(raw) > 1:
+        variants.add(_normalize_authority_text(raw[1:]))
+    return {v for v in variants if v and v not in _GENERIC_AUTHORITY_VALUES}
+
+
+def _browser_ref_labels(untrusted_text: str, ref: str) -> set[str]:
+    labels: set[str] = set()
+    ref_norm = ref.lower().lstrip("@").strip()
+    if not ref_norm:
+        return labels
+    patterns = (f"ref={ref_norm}", f"@{ref_norm}", f"[{ref_norm}]")
+    for line in (untrusted_text or "").splitlines():
+        low = line.lower()
+        if not any(pattern in low for pattern in patterns):
+            continue
+        for quoted in re.findall(r"[\"']([^\"']{2,120})[\"']", line):
+            label = _normalize_authority_text(quoted)
+            if label and label not in {"button", "link", "input", "textbox", ref_norm}:
+                labels.add(label)
+        before = re.sub(r"\[?ref[=:\s]*" + re.escape(ref_norm) + r"\]?", " ", line, flags=re.IGNORECASE)
+        before = re.sub(r"\b(button|link|input|textbox|checkbox|menuitem|heading|ref)\b", " ", before, flags=re.IGNORECASE)
+        before = _normalize_authority_text(before)
+        for token in before.split():
+            if len(token) >= 3 and token not in {ref_norm, "ref"}:
+                labels.add(token)
+    return labels
+
+
+def _trusted_authorizes_browser_ref(value: str, trusted_text: str, untrusted_text: str) -> bool:
+    raw = (value or "").strip()
+    if not _BROWSER_REF_RE.fullmatch(raw.lstrip("@")):
+        return False
+    ref = raw.lower().lstrip("@")
+    trusted_low = (trusted_text or "").lower()
+    if re.search(rf"(?<![a-z0-9])@?{re.escape(ref)}(?![a-z0-9])", trusted_low):
+        return True
+    if _value_in_text(ref, trusted_text) or _value_in_text(f"@{ref}", trusted_text):
+        return True
+    trusted_norm = _normalize_authority_text(trusted_text or "")
+    for label in _browser_ref_labels(untrusted_text, ref):
+        if len(label) >= 3 and label in trusted_norm:
+            return True
+    return False
+
+def _authority_value_variants(value: str) -> set[str]:
+    normalized = _normalize_authority_text(value)
+    if not normalized:
+        return set()
+    variants = {normalized, unquote(normalized)}
+    selector_words = re.sub(r"[^a-z0-9@/_:-]+", " ", normalized).strip()
+    if selector_words:
+        variants.add(selector_words)
+    variants.update(_normalize_authority_text(v) for v in _base64_text_variants(value))
+    variants.update(_normalize_authority_text(v) for v in _decoded_text_fragments(value))
+    variants.update(_browser_selector_value_variants(value))
+    return {v for v in variants if v and v not in _GENERIC_AUTHORITY_VALUES}
+
+
+def _haystack_variants(text: str) -> set[str]:
+    normalized = _normalize_authority_text(text or "")
+    variants = {normalized, _normalize_authority_text(unquote(text or ""))}
+    variants.update(_normalize_authority_text(v) for v in _base64_text_variants(text or ""))
+    variants.update(_normalize_authority_text(v) for v in _decoded_text_fragments(text or ""))
+    return {v for v in variants if v}
+
+
+def _value_in_text(value: str, text: str) -> bool:
+    haystacks = _haystack_variants(text)
+    for variant in _authority_value_variants(value):
+        if len(variant) < 4 or len(variant) > 500:
+            continue
+        if any(variant in haystack for haystack in haystacks):
+            return True
+    return False
+
+
+def _untrusted_parameterized_targets(
+    tool_name: str,
+    action_class: ActionClass,
+    args: Mapping[str, Any] | None,
+    trusted_text: str,
+    combined_untrusted: list[tuple[str | None, str]],
+) -> bool:
+    if not args or not combined_untrusted:
+        return False
+    untrusted_text = "\n".join(body for _, body in combined_untrusted)
+    for value in _authority_target_strings(tool_name, action_class, args):
+        if _value_in_text(value, untrusted_text) and not _value_in_text(value, trusted_text or ""):
+            if tool_name.lower().startswith("browser_") and _trusted_authorizes_browser_ref(value, trusted_text or "", untrusted_text):
+                continue
+            return True
+    return False
+
+
+def _trusted_scopes_action_targets(tool_name: str, action_class: ActionClass, args: Mapping[str, Any] | None, trusted_text: str, combined_untrusted: list[tuple[str | None, str]] | None = None) -> bool:
+    """Return True only when trusted text names the action and its concrete scope.
+
+    Generic trusted requests such as "What time is it?", "What is 1+1?", or
+    "Fix the tests" are not enough to authorize terminal/code execution or other
+    side effects.  The trusted text must contain an action-class signal and each
+    authority-bearing target/scope argument (command, path, recipient, selector,
+    schedule, package, memory content, etc.).
+    """
+    if not _contains_action_signal(trusted_text, action_class):
+        return False
+    targets = _authority_target_strings(tool_name, action_class, args)
+    if not targets:
+        return False
+    untrusted_text = "\n".join(body for _, body in (combined_untrusted or []))
+    for value in targets:
+        if not _value_in_text(value, trusted_text or ""):
+            if tool_name.lower().startswith("browser_") and _trusted_authorizes_browser_ref(value, trusted_text or "", untrusted_text):
+                continue
+            return False
+    return True
+
+
+_HIGH_RISK_BROWSER_ACTIONS = {"browser_click", "browser_type", "browser_press", "browser_dialog", "browser_cdp", "browser_console"}
+
+
+def _browser_action_requires_explicit_scope(tool_name: str, args: Mapping[str, Any] | None, trusted_text: str) -> bool:
+    name = (tool_name or "").lower()
+    if not name.startswith("browser_"):
+        return False
+    if name in {"browser_snapshot", "browser_get_images", "browser_vision", "browser_back", "browser_scroll"}:
+        return False
+    args = args or {}
+    if name == "browser_console" and not str(args.get("expression") or "").strip():
+        return False
+    trusted = trusted_text or ""
+    targets = _authority_target_strings(name, ActionClass.CREDENTIALED_NETWORK_CALL, args)
+    meaningful = [t for t in targets if t and _normalize_authority_text(t) not in _GENERIC_AUTHORITY_VALUES]
+    if not meaningful:
+        return name in _HIGH_RISK_BROWSER_ACTIONS and not _value_in_text(name.replace("browser_", ""), trusted)
+    # Browser refs/selectors/labels/origins are attacker-controlled unless the
+    # exact scope is trusted. Page-derived label-to-ref mapping is not enough:
+    # two controls can share the same visible label, refs can mutate, and hidden
+    # accessible names can deceive the model. Exact trusted scope can be a ref,
+    # URL/origin, selector, or explicit local policy text supplied outside the page.
+    for value in meaningful:
+        if _value_in_text(value, trusted):
+            continue
+        if _trusted_authorizes_browser_ref(value, trusted, ""):
+            continue
+        return True
+    return False
+
+
+def classify_action(tool_name: str, args: Mapping[str, Any] | None = None) -> ActionClass:
+    """Classify a tool call by side-effect class using deterministic metadata.
+
+    The classifier is intentionally conservative for high-impact tools and can
+    be expanded without changing dispatch code.
+    """
+    name = (tool_name or "").lower()
+    args = args or {}
+
+    if name == "read_file" and any(_secretish_path(v) for v in args.values()):
+        return ActionClass.SECRET_READ
+    if name == "browser_console" and str(args.get("expression") or "").strip():
+        return ActionClass.CREDENTIALED_NETWORK_CALL
+    if name in {"terminal", "execute_code"}:
+        command = _stringify(args).lower()
+        if ("curl" in command or "wget" in command or "http" in command) and any(s in command for s in ("secret", "token", ".env", "credential")):
+            return ActionClass.SECRET_TRANSMISSION
+    if name == "skill_manage":
+        action = str(args.get("action", "")).lower()
+        if action in {"install", "update", "enable", "disable", "remove", "delete"}:
+            return ActionClass.SKILL_PLUGIN_INSTALL_UPDATE
+    if name in {"send_email", "discord_send_message", "slack_send_message"} or "email" in name:
+        return ActionClass.OUTBOUND_MESSAGE
+    return _TOOL_ACTION_CLASSES.get(name, ActionClass.UNKNOWN_SIDE_EFFECT)
+
+
+def evaluate_action_authority(
+    tool_name: str,
+    args: Mapping[str, Any] | None = None,
+    *,
+    trusted_user_intent: str | None = None,
+    policy_allows_without_user_intent: bool = False,
+    prior_untrusted_context: str | None = None,
+) -> ActionAuthorityResult:
+    name = (tool_name or "").lower()
+    action_class = classify_action(tool_name, args)
+    arg_text = _stringify(args or {})
+    user_text = trusted_user_intent or ""
+    prior_text = prior_untrusted_context or ""
+    combined_untrusted = _untrusted_blocks(arg_text) + _untrusted_blocks(user_text) + _untrusted_blocks(prior_text)
+    if prior_text and not _untrusted_blocks(prior_text):
+        combined_untrusted.append(("prior_untrusted_tool_result", prior_text))
+    trusted_text = _trusted_text_without_untrusted(user_text)
+
+    if action_class == ActionClass.READ_ONLY_NETWORK_FETCH:
+        risk = _network_egress_risk(args, trusted_text, combined_untrusted)
+        if risk:
+            decision, reason, source = risk
+            return ActionAuthorityResult(decision, action_class, reason=reason, source=source)
+        return ActionAuthorityResult(AuthorityDecision.ALLOW, action_class)
+
+    if action_class == ActionClass.READ_ONLY_LOCAL_INSPECTION:
+        return ActionAuthorityResult(AuthorityDecision.ALLOW, action_class)
+
+    if action_class == ActionClass.AGENT_LOOP_INTERNAL:
+        if policy_allows_without_user_intent or name in EXPLICIT_TOOL_EXEMPTIONS:
+            return ActionAuthorityResult(AuthorityDecision.ALLOW, action_class, source="agent_loop_internal")
+        return ActionAuthorityResult(AuthorityDecision.REQUIRE_CONFIRMATION, action_class, reason="agent-loop tool requires explicit mediation", source="trusted_confirmation_required")
+
+    if action_class == ActionClass.UNKNOWN_SIDE_EFFECT:
+        if combined_untrusted:
+            return ActionAuthorityResult(AuthorityDecision.BLOCK, action_class, reason="unknown side-effecting action cannot be authorized by untrusted context", source=next((src for src, _ in combined_untrusted if src), "untrusted_context"))
+        return ActionAuthorityResult(AuthorityDecision.REQUIRE_CONFIRMATION, action_class, reason="unknown tool side-effect behavior requires confirmation unless explicitly classified", source="trusted_confirmation_required")
+
+    if combined_untrusted:
+        untrusted_has_action = any(_contains_action_signal(body, action_class) for _, body in combined_untrusted)
+        trusted_has_action = _contains_action_signal(trusted_text, action_class)
+        args_contain_untrusted = bool(_untrusted_blocks(arg_text))
+        high_risk_untrusted_action = action_class in {ActionClass.SECRET_READ, ActionClass.SECRET_TRANSMISSION}
+        args_parameterized_by_untrusted = _untrusted_parameterized_targets(name, action_class, args, trusted_text, combined_untrusted)
+        if args_contain_untrusted or high_risk_untrusted_action or args_parameterized_by_untrusted or (untrusted_has_action and not trusted_has_action):
+            source = next((src for src, _ in combined_untrusted if src), "untrusted_context")
+            return ActionAuthorityResult(
+                AuthorityDecision.BLOCK,
+                action_class,
+                reason="side-effecting action was requested or parameterized by evidence-only untrusted context",
+                source=source,
+            )
+
+    if name.startswith("browser_") and _browser_action_requires_explicit_scope(name, args, trusted_text):
+        return ActionAuthorityResult(
+            AuthorityDecision.REQUIRE_CONFIRMATION,
+            action_class,
+            reason="high-risk browser action requires exact trusted origin/action/target scope; page labels, refs, selectors, accessible names, and DOM text are evidence-only",
+            source="trusted_confirmation_required",
+        )
+
+    if _trusted_scopes_action_targets(name, action_class, args, trusted_text, combined_untrusted):
+        return ActionAuthorityResult(AuthorityDecision.ALLOW, action_class, source="trusted_scoped_intent")
+
+    return ActionAuthorityResult(
+        AuthorityDecision.REQUIRE_CONFIRMATION,
+        action_class,
+        reason="side-effecting action lacks explicit trusted scoped authority for action class and target/scope",
+        source="trusted_confirmation_required",
+    )
