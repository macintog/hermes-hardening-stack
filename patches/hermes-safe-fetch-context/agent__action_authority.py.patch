+    "spotify_library": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "spotify_playback": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "spotify_queue": ActionClass.CREDENTIALED_NETWORK_CALL,
+    "discord": ActionClass.OUTBOUND_MESSAGE,
