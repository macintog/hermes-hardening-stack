+def test_redact_url_removes_signed_path_segments_and_sensitive_headers():
+    redacted = redact_url("https://files.example/download/secret-token-abc12345678901234567890/report.pdf?X-Amz-Signature=abc#frag")
+    assert redacted == "https://files.example/download/<redacted>/report.pdf"
