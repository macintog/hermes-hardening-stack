+@pytest.mark.asyncio
+async def test_redirect_to_private_target_is_blocked_before_following(monkeypatch):
+    calls = []
+
+    def fake_safe(url):
+        calls.append(url)
+        return not url.startswith("http://127.0.0.1")
+
+    monkeypatch.setattr("tools.safe_http.is_safe_url", fake_safe)
+
+    async def handler(request):
+        assert str(request.url) == "https://files.example/report.pdf?token=secret"
+        return httpx.Response(302, headers={"Location": "http://127.0.0.1/admin"})
+
+    with pytest.raises(SafeHTTPError) as exc:
+        await safe_download_bytes(
+            "https://files.example/report.pdf?token=secret",
+            max_bytes=1024,
+            source_type="test",
+            policy={"caller": "test"},
+            transport=httpx.MockTransport(handler),
+        )
+
+    assert calls == ["https://files.example/report.pdf?token=secret", "http://127.0.0.1/admin"]
+    assert "token=secret" not in str(exc.value)
+
