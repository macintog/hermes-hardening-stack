+@pytest.mark.asyncio
+@pytest.mark.parametrize(
+    ("content_type", "content"),
+    [
+        ("audio/webm", b"\x1aE\xdf\xa3" + b"\x00" * 16 + b"webm" + b"\x00" * 16),
+        ("audio/mp4", b"\x00\x00\x00\x18ftypM4A \x00\x00\x00\x00M4A "),
+        ("audio/aac", b"\xff\xf1\x50\x80\x00\x1f\xfc" + b"\x00" * 8),
+    ],
+)
+async def test_declared_audio_container_magic_is_accepted(monkeypatch, content_type, content):
+    monkeypatch.setattr("tools.safe_http.is_safe_url", lambda _url: True)
+
+    async def handler(request):
+        return httpx.Response(200, headers={"Content-Type": content_type}, content=content)
+
+    result = await safe_download_bytes(
+        "https://files.example/audio",
+        max_bytes=1024,
+        source_type="test",
+        allowed_content_types=(content_type,),
+        transport=httpx.MockTransport(handler),
+    )
+    assert result.content == content
+
+
