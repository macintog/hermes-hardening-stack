+@pytest.mark.asyncio
+async def test_authorization_not_sent_cross_origin_redirect(monkeypatch):
+    monkeypatch.setattr("tools.safe_http.is_safe_url", lambda _url: True)
+    seen_auth = []
+
+    async def handler(request):
+        seen_auth.append((str(request.url), request.headers.get("Authorization")))
+        if request.url.host == "files.example":
+            return httpx.Response(302, headers={"Location": "https://evil.example/steal"})
+        raise AssertionError("cross-origin redirect should be blocked before second request")
+
+    with pytest.raises(SafeHTTPError, match="credential-bearing cross-origin redirect"):
+        await safe_download_bytes(
+            "https://files.example/private.bin",
+            max_bytes=1024,
+            source_type="test",
+            headers={"Authorization": "Bearer secret"},
+            transport=httpx.MockTransport(handler),
+        )
+
+    assert seen_auth == [("https://files.example/private.bin", "Bearer secret")]
+
+
+@pytest.mark.asyncio
+async def test_stream_time_http_error_is_wrapped(monkeypatch):
+    monkeypatch.setattr("tools.safe_http.is_safe_url", lambda _url: True)
+
+    class FailingStream(httpx.AsyncByteStream):
+        async def __aiter__(self):
+            yield b"partial"
+            raise httpx.ReadError("stream broke")
+
+    async def handler(request):
+        return httpx.Response(200, stream=FailingStream(), request=request)
+
+    with pytest.raises(SafeHTTPError, match="HTTP download failed.*ReadError") as exc:
+        await safe_download_bytes(
+            "https://files.example/flaky.bin?token=secret",
+            max_bytes=1024,
+            source_type="test",
+            policy={"caller": "test"},
+            transport=httpx.MockTransport(handler),
+        )
+
+    assert isinstance(exc.value.__cause__, httpx.ReadError)
+    assert "token=secret" not in str(exc.value)
+
+
+@pytest.mark.asyncio
+async def test_result_metadata_and_redaction(monkeypatch):
+    monkeypatch.setattr("tools.safe_http.is_safe_url", lambda _url: True)
+
+    async def handler(request):
+        return httpx.Response(200, headers={"Content-Type": "application/pdf"}, content=b"pdf")
+
+    result = await safe_download_bytes(
+        "https://user:pass@files.example/report.pdf?X-Amz-Signature=secret#frag",
+        max_bytes=10,
+        source_type="test",
+        policy={"caller": "test"},
+        allow_userinfo=True,
+        transport=httpx.MockTransport(handler),
+    )
+
+    assert result.content == b"pdf"
+    assert result.source_url == "https://files.example/report.pdf"
+    assert result.final_url == "https://files.example/report.pdf"
+    assert "user:pass" not in result.source_url
+    assert "X-Amz-Signature" not in result.source_url
+    assert "#frag" not in result.source_url
+    assert "user:pass" not in result.final_url
+    assert "X-Amz-Signature" not in result.final_url
+    assert "#frag" not in result.final_url
+    assert result.status_code == 200
+    assert result.bytes_read == 3
+    assert result.sha256 == "c35b21d6ca39aa7cc3b79a705d989f1a6e88b99ab43988d74048799e3db926a3"
+    assert result.content_type == "application/pdf"
+    assert result.content_length == 3
+    assert result.source_type == "test"
+    assert result.policy["caller"] == "test"
+    assert redact_url("https://user:pass@files.example/report.pdf?token=secret#frag") == "https://files.example/report.pdf"
+
+
+@pytest.mark.asyncio
+async def test_allowed_private_origin_download_and_same_origin_redirect(monkeypatch):
+    monkeypatch.setattr("tools.safe_http.is_safe_url", lambda _url: False)
+    requested_urls = []
+
+    async def handler(request):
+        requested_urls.append(str(request.url))
+        if request.url.path == "/api/v4/files/file_private":
+            return httpx.Response(302, headers={"Location": "/api/v4/files/file_private/download"})
+        return httpx.Response(200, headers={"Content-Type": "text/plain"}, content=b"ok")
+
+    result = await safe_download_bytes(
+        "http://127.0.0.1:8065/api/v4/files/file_private",
+        max_bytes=1024,
+        source_type="test",
+        policy={"caller": "test"},
+        allowed_private_origins=("http://127.0.0.1:8065",),
+        transport=httpx.MockTransport(handler),
+    )
+
+    assert result.content == b"ok"
+    assert requested_urls == [
+        "http://127.0.0.1:8065/api/v4/files/file_private",
+        "http://127.0.0.1:8065/api/v4/files/file_private/download",
+    ]
+
