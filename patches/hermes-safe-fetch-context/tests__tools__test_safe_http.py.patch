+import pytest
+import httpx
+
+from tools.safe_http import SafeHTTPError, safe_download_bytes, redact_url
+
+
+@pytest.mark.asyncio
+async def test_unsafe_initial_url_blocked_before_request(monkeypatch):
+    monkeypatch.setattr("tools.safe_http.is_safe_url", lambda _url: False)
+
+    async def handler(request):
+        raise AssertionError("unsafe initial URL should be blocked before request")
+
+    with pytest.raises(SafeHTTPError, match="unsafe URL target") as exc:
+        await safe_download_bytes(
+            "http://127.0.0.1:8080/metadata?token=secret#frag",
+            max_bytes=1024,
+            source_type="test",
+            policy={"caller": "test"},
+            transport=httpx.MockTransport(handler),
+        )
+
+    assert "token=secret" not in str(exc.value)
+    assert "#frag" not in str(exc.value)
+
+
+@pytest.mark.asyncio
+async def test_missing_host_and_userinfo_blocked_by_default(monkeypatch):
+    monkeypatch.setattr("tools.safe_http.is_safe_url", lambda _url: True)
+
+    with pytest.raises(SafeHTTPError, match="missing host"):
+        await safe_download_bytes("https:///missing", max_bytes=10, source_type="test")
+
+    with pytest.raises(SafeHTTPError, match="embedded credentials") as exc:
+        await safe_download_bytes(
+            "https://user:pass@files.example/report.pdf?X-Amz-Signature=secret",
+            max_bytes=10,
+            source_type="test",
+        )
+    assert "user:pass" not in str(exc.value)
+    assert "X-Amz-Signature" not in str(exc.value)
+
