+@pytest.mark.asyncio
+async def test_chunked_response_over_cap_is_rejected_while_streaming(monkeypatch):
+    monkeypatch.setattr("tools.safe_http.is_safe_url", lambda _url: True)
+    chunks_yielded = []
+
+    class ChunkedStream(httpx.AsyncByteStream):
+        async def __aiter__(self):
+            for chunk in (b"ab", b"cd", b"e", b"this-must-not-be-read"):
+                chunks_yielded.append(chunk)
+                yield chunk
+
+    async def handler(request):
+        return httpx.Response(200, stream=ChunkedStream())
+
+    with pytest.raises(SafeHTTPError, match="too large"):
+        await safe_download_bytes(
+            "https://files.example/chunked.bin",
+            max_bytes=4,
+            source_type="test",
+            policy={"caller": "test"},
+            transport=httpx.MockTransport(handler),
+        )
+
+    assert chunks_yielded == [b"ab", b"cd", b"e"]
+
+
