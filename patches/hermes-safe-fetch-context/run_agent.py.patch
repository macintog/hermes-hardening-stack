+    @staticmethod
+    def _message_text_content(msg: dict) -> str:
+        content = msg.get("content")
+        if isinstance(content, str):
+            return content
+        if isinstance(content, list):
+            parts: list[str] = []
+            for part in content:
+                if isinstance(part, dict):
+                    text = part.get("text") or part.get("content")
+                    if isinstance(text, str):
+                        parts.append(text)
+                elif isinstance(part, str):
+                    parts.append(part)
+            return "\n".join(parts)
+        return ""
+
+    @staticmethod
+    def _untrusted_fence_snippets(text: str) -> str:
+        import re as _re
+        return "\n\n".join(
+            match.group(0)
+            for match in _re.finditer(
+                r"<untrusted-context\b[^>]*>.*?</untrusted-context>",
+                text or "",
+                _re.IGNORECASE | _re.DOTALL,
+            )
+        )
+
+    @classmethod
+    def _trusted_authority_text_from_user_message(cls, msg: dict) -> str:
+        content = cls._message_text_content(msg)
+        active = msg.get("__active_user_intent")
+        if isinstance(active, dict):
+            active_text = str(active.get("active_text") or "")
+            # Evidence-only spans are deliberately excluded from trusted authority.
+            # They remain model-visible in the user message body and are collected
+            # separately as prior untrusted context for the action gate.
+            return active_text
+        if isinstance(active, str):
+            return active.strip()
+        return content
+
+    @classmethod
+    def _latest_trusted_user_intent(cls, messages: list | None) -> str:
+        if messages:
+            for _msg in reversed(messages):
+                if isinstance(_msg, dict) and _msg.get("role") == "user":
+                    return cls._trusted_authority_text_from_user_message(_msg)
+        return ""
+
+    @staticmethod
+    def _strip_internal_message_fields(api_msg: dict) -> None:
+        for internal_field in (
+            "reasoning", "finish_reason", "_thinking_prefill",
+            "__active_user_intent", "__intent_segments",
+        ):
+            api_msg.pop(internal_field, None)
+
+    @staticmethod
+    def _collect_prior_untrusted_context(messages: list | None) -> str | None:
+        """Return recent model-visible tool/evidence text.
+
+        Tool outputs and injected evidence are not authority. The action gate
+        needs this side channel because the model may transform hostile evidence
+        into clean-looking tool arguments that no longer contain visible fence
+        markers. We do not stop at the latest user turn: browser/page evidence
+        from a previous turn can still parameterize a later click/type/navigation.
+        """
+        if not messages:
+            return None
+        collected: list[str] = []
+        for msg in reversed(messages):
+            if not isinstance(msg, dict):
+                continue
+            role = msg.get("role")
+            if role not in {"tool", "assistant", "user"}:
+                continue
+            text = AIAgent._message_text_content(msg)
+            if not text.strip():
+                continue
+            if role == "assistant" and "<untrusted-context" not in text.lower():
+                continue
+            if role == "user":
+                fenced = AIAgent._untrusted_fence_snippets(text)
+                if not fenced:
+                    continue
+                text = fenced
+            collected.append(text)
+            if len(collected) >= 32:
+                break
+        if not collected:
+            return None
+        return "\n\n".join(reversed(collected))
+
