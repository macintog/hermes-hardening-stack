+import asyncio
+
+import httpx
+import pytest
+
+
+def _safe_http_client(handler):
+    real_async_client = httpx.AsyncClient
+
+    def factory(*args, **kwargs):
+        kwargs["transport"] = httpx.MockTransport(handler)
+        return real_async_client(*args, **kwargs)
+
+    return factory
+
+
+def test_cache_image_from_url_uses_safe_http_and_caches_bytes(tmp_path, monkeypatch):
+    from gateway.platforms.base import cache_image_from_url
+
+    monkeypatch.setattr("gateway.platforms.base.IMAGE_CACHE_DIR", tmp_path / "img")
+    captured = {}
+
+    async def handler(request):
+        captured["accept"] = request.headers.get("accept")
+        return httpx.Response(
+            200,
+            headers={"Content-Type": "image/png"},
+            content=b"\x89PNG\r\n\x1a\n fake png",
+        )
+
+    monkeypatch.setattr("tools.safe_http.is_safe_url", lambda _url: True)
+    monkeypatch.setattr("tools.safe_http.httpx.AsyncClient", _safe_http_client(handler))
+
+    path = asyncio.run(cache_image_from_url("https://cdn.example.test/image.png", ext=".png", retries=0))
+
+    assert path.endswith(".png")
+    assert (tmp_path / "img").exists()
+    assert captured["accept"].startswith("image/")
+
+
