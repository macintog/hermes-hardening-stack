+def test_cache_image_from_url_error_redacts_credentials_and_query(tmp_path, monkeypatch):
+    from gateway.platforms.base import cache_image_from_url
+    from tools.safe_http import SafeHTTPError
+
+    monkeypatch.setattr("gateway.platforms.base.IMAGE_CACHE_DIR", tmp_path / "img")
+
+    with pytest.raises(SafeHTTPError) as excinfo:
+        asyncio.run(cache_image_from_url("https://user:secret@cdn.example.test/image.png?sig=abc", ext=".png", retries=0))
+
+    message = str(excinfo.value)
+    assert "user:secret" not in message
+    assert "sig=abc" not in message
+
