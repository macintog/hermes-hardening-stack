+def test_cache_image_from_url_blocks_redirect_to_private_target(tmp_path, monkeypatch):
+    from gateway.platforms.base import cache_image_from_url
+    from tools.safe_http import SafeHTTPError
+
+    monkeypatch.setattr("gateway.platforms.base.IMAGE_CACHE_DIR", tmp_path / "img")
+
+    async def handler(request):
+        if str(request.url) == "https://public.example.test/image.png":
+            return httpx.Response(302, headers={"Location": "http://169.254.169.254/latest/meta-data"})
+        return httpx.Response(200, headers={"Content-Type": "image/png"}, content=b"\x89PNG\r\n\x1a\n")
+
+    monkeypatch.setattr(
+        "tools.safe_http.is_safe_url",
+        lambda url: not str(url).startswith("http://169.254.169.254"),
+    )
+    monkeypatch.setattr("tools.safe_http.httpx.AsyncClient", _safe_http_client(handler))
+
+    with pytest.raises(SafeHTTPError, match="Blocked unsafe URL target"):
+        asyncio.run(cache_image_from_url("https://public.example.test/image.png", ext=".png", retries=0))
+
+
+def test_cache_audio_from_url_blocks_oversized_stream(tmp_path, monkeypatch):
+    from gateway.platforms.base import MEDIA_CACHE_MAX_BYTES, cache_audio_from_url
+    from tools.safe_http import SafeHTTPError
+
+    monkeypatch.setattr("gateway.platforms.base.AUDIO_CACHE_DIR", tmp_path / "audio")
+
+    async def handler(request):
+        return httpx.Response(
+            200,
+            headers={"Content-Type": "audio/ogg"},
+            content=b"x" * (MEDIA_CACHE_MAX_BYTES + 1),
+        )
+
+    monkeypatch.setattr("tools.safe_http.is_safe_url", lambda _url: True)
+    monkeypatch.setattr("tools.safe_http.httpx.AsyncClient", _safe_http_client(handler))
+
+    with pytest.raises(SafeHTTPError, match="Response too large"):
+        asyncio.run(cache_audio_from_url("https://cdn.example.test/voice.ogg", ext=".ogg", retries=0))
+
